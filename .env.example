# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database-name>
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-project

# Frontend URL (for CORS and Better Auth trustedOrigins)
# After Vercel deployment, replace with your actual Vercel URL
CLIENT_URL=https://your-app.vercel.app

# Better Auth Configuration
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate_with_openssl_rand_base64_32
# After Render deployment, replace with your actual Render URL including /api/auth
BETTER_AUTH_URL=https://your-app.onrender.com/api/auth

# Google OAuth (Optional - for social login)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
